{  "manifest_version": 3,  "name": "should-i-buy-this.ai",  "version": "1.0",  "description": "A Chrome extension to help you decide whether to buy something.",  "permissions": ["storage", "activeTab"],  "background": {    "service_worker": "background.js"  },  "action": {    "default_popup": "popup.html",    "default_icon": "icon.png"  },  "icons": {    "48": "icon.png"  },  "content_scripts": [{    "matches": ["<all_urls>"],    "js": ["content.js"]  }]  }